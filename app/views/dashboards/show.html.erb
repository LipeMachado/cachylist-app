<%= render layout: "shared/app_shell" do %>
  <section class="dashboard-mobile">
    <header class="mobile-topbar">
      <button class="mobile-icon-button" type="button" aria-label="Abrir menu" data-action="mobile-menu#open"><%= lucide_icon "menu", size: 23 %></button>
      <%= link_to dashboard_path, class: "mobile-brand" do %><%= image_tag "logo.png", alt: "CachyList", class: "h-8 w-auto" %><% end %>
      <%= link_to library_path, class: "mobile-icon-button", aria: { label: "Buscar" } do %><%= lucide_icon "search", size: 22 %><% end %>
    </header>
    <div class="mobile-profile-row">
      <button type="button" class="mobile-avatar" data-action="modal#openAvatarModal" aria-label="Editar avatar">
        <% if (avatar = avatar_image_for(current_user)) %>
          <%= image_tag avatar, alt: "Avatar de #{current_user.display_name}" %>
        <% else %>
          <span><%= current_user.display_name.first %></span>
        <% end %>
      </button>
      <%= link_to user_path(current_user), class: "mobile-profile-link" do %>
        <strong><%= current_user.display_name %></strong>
        <span>Ver perfil ↗</span>
      <% end %>
    </div>
    <div class="mobile-hero brutalist-noise">
      <div class="brutalist-noise-content">
        <p class="brutalist-kicker mb-5">Resumo geral</p>
        <h1>Sua biblioteca.<br>
          Seu mundo.</h1>
        <p>Organize tudo o que você assiste, joga, lê e acompanha. Um painel seco, escuro e direto para seu acervo.</p>
      </div>
    </div>
    <div class="mobile-stats-grid">
      <div><strong data-dashboard-stat="total"><%= @stats.total %></strong><span>Total</span></div>
      <div><strong data-dashboard-stat="completed"><%= @stats.count(:completed) %></strong><span>Finalizadas</span></div>
      <div><strong data-dashboard-stat="in_progress"><%= @stats.count(:in_progress) %></strong><span>Ativas</span></div>
      <div><strong data-dashboard-stat="planned"><%= @stats.count(:planned) %></strong><span>Planejadas</span></div>
      <div><strong data-dashboard-stat="completed_percentage"><%= @stats.percentage(:completed) %>%</strong><span>Conclusão</span></div>
    </div>
    <section class="mobile-section">
      <div class="mobile-section-header">
        <h2>Continue de onde parou</h2>
        <%= link_to "Ver tudo →", library_path %>
      </div>
      <div class="mobile-progress-list">
        <% @continue_items.each do |item| %>
          <% progress = item.progress_percentage %>
          <%= link_to media_item_path(item), class: "mobile-progress-card" do %>
            <%= image_tag cover_for(item), alt: "Capa de #{item.title}" %>
            <div class="mobile-card-copy">
              <div class="mobile-card-title"><strong><%= item.title %></strong><span class="status-dot <%= status_class(item.status) %>"></span></div>
              <p><%= category_label(item.category) %> • <%= item.release_year.presence || "----" %></p>
              <small><%= item.progress_label.presence || item.platform.presence || "-" %></small>
              <div class="mobile-progress-line"><span style="width: <%= progress %>%"></span></div>
            </div>
            <div class="mobile-progress-meta"><span><%= progress %>%</span><span class="mobile-play"><%= lucide_icon "play", size: 13 %></span></div>
          <% end %>
        <% end %>
      </div>
    </section>
    <section class="mobile-section">
      <div class="mobile-section-header">
        <h2>Últimos adicionados</h2>
        <%= link_to "Ver tudo →", library_path %>
      </div>
      <div class="mobile-latest-list">
        <% @latest_items.each do |item| %>
          <%= link_to media_item_path(item), class: "mobile-latest-card" do %>
            <%= image_tag cover_for(item), alt: "Capa de #{item.title}" %>
            <div class="mobile-card-copy">
              <div class="mobile-card-title"><strong><%= item.title %></strong><span class="status-dot <%= status_class(item.status) %>"></span></div>
              <p><%= category_label(item.category) %> • <%= item.release_year.presence || "----" %></p>
              <small><%= item.progress_label.presence || item.platform.presence || "-" %></small>
            </div>
            <span class="mobile-grip"><%= lucide_icon "grip-vertical", size: 14 %></span>
          <% end %>
        <% end %>
      </div>
    </section>
  </section>
  <div class="dashboard-desktop">
    <div data-motion class="grid grid-cols-[1fr_minmax(280px,360px)_auto] items-stretch h-20 overflow-hidden border-b border-[var(--line)] bg-[var(--panel-bg)]">
      <div class="px-8 py-3 border-r border-[var(--line)] flex flex-col justify-center">
        <h1 class="text-[13px] leading-none m-0 font-black tracking-[.32em] uppercase">Seu acervo</h1>
      </div>
      <%= form_with url: library_path, method: :get, class: "relative grid items-center h-full", data: { controller: "search-dropdown", search_dropdown_items_value: @search_suggestions.to_json, action: "click@window->search-dropdown#clickOutside" } do |form| %>
        <%= form.search_field :query, placeholder: "Buscar por título, plataforma, categoria...", autocomplete: "off", class: "min-h-0 border-0 py-3 px-8 text-sm bg-transparent text-[var(--text)] w-full outline-none placeholder:text-[var(--tertiary)] placeholder:text-[13px] hover:bg-[var(--hover-bg)] focus:bg-[var(--hover-bg)]", data: { search_dropdown_target: "input", action: "input->search-dropdown#search focus->search-dropdown#search" } %>
        <div data-search-dropdown-target="results" hidden class="absolute left-0 right-0 top-full z-50 border border-[var(--line)] border-t-0 bg-[var(--panel-bg)] max-h-[280px] overflow-y-auto"></div>
      <% end %>
      <%= link_to "#", class: "inline-flex items-center justify-center min-h-full px-8 bg-transparent border-l border-[var(--line)] text-[var(--text)] text-[11px] font-bold tracking-[.16em] uppercase whitespace-nowrap cursor-pointer font-inherit transition-[background,color] duration-150 hover:bg-[var(--hover-bg)]", data: { action: "modal#open" } do %><%= lucide_icon "plus", size: 16 %> Adicionar<% end %>
    </div>
    <section data-motion class="grid grid-cols-[minmax(0,1fr)_340px] border-b border-[var(--line)] min-h-[390px]">
      <div class="relative px-8 lg:px-10 py-12 border-r border-[var(--line)] overflow-hidden brutalist-noise">
        <% highlighted_bars = @stats.total.positive? ? [(@stats.total / 5.0).ceil, 72].min : 0 %>
        <% if highlighted_bars.positive? %>
          <div class="library-pulse-bars" aria-hidden="true" data-controller="random-scan">
            <% highlighted_bars.times do |index| %>
              <span style="--bar-index: <%= index %>; --bar-count: <%= highlighted_bars %>"><i></i></span>
            <% end %>
          </div>
        <% end %>
        <div class="brutalist-noise-content">
          <p class="brutalist-kicker mb-7">Resumo geral</p>
          <h2 class="max-w-[720px] text-[clamp(46px,6vw,82px)] leading-[.92] font-black uppercase tracking-[-.08em] m-0">Sua biblioteca.<br>
            Seu mundo.</h2>
          <p class="mt-8 max-w-[520px] text-[15px] leading-7 text-[var(--muted)]">Organize tudo o que você assiste, joga, lê e acompanha. Um painel seco, escuro e direto para seu acervo.</p>
          <div class="mt-9 pt-7 border-t border-[var(--line)] grid grid-cols-5 gap-6 max-w-[760px]">
            <div><strong class="block text-2xl font-black" data-dashboard-stat="total"><%= @stats.total %></strong><span class="brutalist-kicker">Total</span></div>
            <div><strong class="block text-2xl font-black" data-dashboard-stat="completed"><%= @stats.count(:completed) %></strong><span class="brutalist-kicker">Finalizadas</span></div>
            <div><strong class="block text-2xl font-black" data-dashboard-stat="in_progress"><%= @stats.count(:in_progress) %></strong><span class="brutalist-kicker">Ativas</span></div>
            <div><strong class="block text-2xl font-black" data-dashboard-stat="planned"><%= @stats.count(:planned) %></strong><span class="brutalist-kicker">Planejadas</span></div>
            <div><strong class="block text-2xl font-black" data-dashboard-stat="completed_percentage"><%= @stats.percentage(:completed) %>%</strong><span class="brutalist-kicker">Conclusão</span></div>
          </div>
        </div>
      </div>
      <aside class="px-7 py-8 bg-[var(--panel-bg)]">
        <p class="brutalist-kicker mb-8">Indicadores</p>
        <div class="grid gap-0 border-y border-[var(--line)]">
          <div class="py-5 border-b border-[var(--line)]"><strong class="text-4xl font-black" data-dashboard-stat="total"><%= @stats.total %></strong><span class="ml-3 brutalist-kicker">itens na biblioteca</span></div>
          <div class="py-5 border-b border-[var(--line)]"><strong class="text-4xl font-black" data-dashboard-stat="completed"><%= @stats.count(:completed) %></strong><span class="ml-3 brutalist-kicker">concluídas</span></div>
          <div class="py-5 border-b border-[var(--line)]"><strong class="text-4xl font-black" data-dashboard-stat="paused"><%= @stats.count(:paused) %></strong><span class="ml-3 brutalist-kicker">pausadas</span></div>
          <div class="py-5"><strong class="text-4xl font-black" data-dashboard-stat="completed_percentage"><%= @stats.percentage(:completed) %>%</strong><span class="ml-3 brutalist-kicker">conclusão média</span></div>
        </div>
      </aside>
    </section>
    <section data-motion class="bg-transparent p-0">
      <div class="min-h-[72px] px-10 border-b border-[var(--line)] flex justify-between items-center">
        <h2 class="m-0 brutalist-kicker">Continue de onde parou</h2>
        <%= link_to "Ver tudo →", library_path, class: "brutalist-link inline-flex items-center justify-center w-fit min-h-[48px] border-0 px-[22px] whitespace-nowrap cursor-pointer transition-opacity duration-200 hover:opacity-75" %>
      </div>
      <div class="flex overflow-x-auto border-b border-[var(--line)] min-h-[420px]" data-controller="kanban" data-kanban-dragging-class="is-dragging" data-kanban-drag-over-class="is-drag-over">
        <% @items_by_status.each do |status, items| %>
          <div class="kanban-column border-r border-[var(--line)] bg-[var(--column-bg)] [&:last-child]:border-r-0" data-kanban-target="column" data-kanban-status="<%= status %>" data-action="dragover->kanban#allowDrop dragenter->kanban#dragEnter dragleave->kanban#dragLeave drop->kanban#drop">
            <header class="min-h-[60px] px-6 border-b border-[var(--line)] flex items-center gap-2 text-[10px] font-bold tracking-[.16em] uppercase text-[var(--muted)]">
              <span class="w-1.5 h-1.5 bg-[var(--accent)] inline-block flex-[0_0_6px] <%= status_class(status) %>"></span>
              <strong class="font-bold text-[var(--muted)] truncate"><%= status_label(status) %></strong>
              <small class="ml-auto text-[var(--tertiary)] text-[11px] tracking-[.04em]"><%= @stats.count(status) %></small>
              <%= render "shared/kanban_add_button", status: status %>
            </header>
            <% items.each do |item| %>
              <%= render "shared/media_card", item: item %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  </div>
<% end %>
