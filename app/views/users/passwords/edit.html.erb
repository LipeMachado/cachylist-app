<section class="auth-page">
  <div class="auth-art"></div>
  <div class="auth-panel">
    <span class="logo-script">CACHYLIST</span>
    <p>Defina uma nova senha.</p>
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= render "users/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>
      <label>Nova senha<%= f.password_field :password, autofocus: true, autocomplete: "new-password" %></label>
      <label>Confirmar senha<%= f.password_field :password_confirmation, autocomplete: "new-password" %></label>
      <%= f.submit "Alterar senha", class: "primary-button full" %>
    <% end %>
  </div>
</section>
