<section class="w-screen min-h-screen relative grid grid-cols-1 overflow-hidden bg-[var(--page-bg)]">
  <div class="auth-art min-h-screen hidden"></div>
  <div class="relative z-10 flex flex-col justify-center w-[min(520px,88vw)] mx-auto px-2 md:px-5">
    <%= link_to "/" do %><%= image_tag "logo.png", alt: "CachyList", class: "h-20 w-auto mx-auto block mb-5" %><% end %>
    <p class="text-[#c4c0ca] text-[1.15rem] mb-[42px] text-center">Seu lugar. Suas histórias.</p>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "grid gap-5" }) do |f| %>
      <label class="text-[var(--text)] grid gap-2.5 font-semibold">E-mail<%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "seu@email.com", class: "w-full border border-[var(--line)] text-[var(--text)] bg-[var(--field-bg)] px-3 py-[15px] outline-none" %></label>
      <label class="text-[#ddd9e7] grid gap-2.5 font-semibold">Senha
        <span class="relative block" data-controller="password-visibility">
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "w-full border border-[var(--line)] text-[var(--text)] bg-[var(--field-bg)] px-3 py-[15px] outline-none", data: { password_visibility_target: "input" } %>
          <button type="button" data-action="password-visibility#toggle" class="absolute right-px top-px bottom-px w-9 border-0 bg-transparent text-[var(--muted)] grid place-items-center cursor-pointer p-0 font-inherit transition-colors duration-150 hover:text-white" tabindex="-1" aria-label="Mostrar senha">
            <span data-icon="on"><%= lucide_icon "eye", size: 16 %></span>
            <span data-icon="off" hidden><%= lucide_icon "eye-off", size: 16 %></span>
          </button>
        </span>
      </label>
      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-2.5 text-[var(--muted)]"><%= f.check_box :remember_me, class: "appearance-none w-5 h-5 inline-grid place-items-center flex-[0_0_20px] m-0 p-0 border border-[var(--line)] bg-[var(--field-bg)]" %> Lembrar de mim</label>
      <% end %>
      <%= f.submit "Entrar", class: "primary-button inline-flex items-center justify-center w-full min-h-[54px] border-0 px-7 text-white font-extrabold cursor-pointer whitespace-nowrap" %>
    <% end %>
    <div class="flex items-center gap-[18px] text-[#878493] my-7"><span>ou</span></div>
    <%= link_to "Criar conta", new_registration_path(resource_name), class: "inline-flex items-center justify-center w-full min-h-[48px] px-[22px] border border-[var(--line)] text-[var(--accent-strong)] bg-transparent font-bold whitespace-nowrap cursor-pointer transition-[background,opacity,border-color] duration-200 hover:bg-[var(--hover-bg)]" %>
    <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "auth-link text-[var(--purple-2)] mt-7 text-center font-bold transition-opacity duration-200 hover:opacity-75" %>
  </div>
</section>
