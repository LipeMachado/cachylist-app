<% content_for :title, "CachyList" %>

<section class="landing-hero relative h-screen flex flex-col overflow-hidden px-[min(6vw,80px)] py-12">
  <header class="landing-header relative z-10 flex items-center justify-between">
    <span class="logo-script text-[var(--purple-2)] font-['Bebas_Neue',Inter,sans-serif] text-[clamp(3rem,7vw,5rem)] italic tracking-[-.04em]">CACHYLIST</span>
    <%= link_to (user_signed_in? ? dashboard_path : new_user_session_path), class: "landing-login flex items-center gap-2.5 text-[var(--text)] font-bold text-sm px-6 py-2.5 border border-[var(--line)] bg-transparent transition-colors duration-200 hover:bg-[var(--hover-bg)]" do %>Entrar <%= lucide_icon "arrow-right", size: 14 %><% end %>
  </header>

  <div class="landing-copy relative z-10 w-[min(560px,92vw)] mt-[12vh]">
    <h1 class="font-['Bebas_Neue',Inter,sans-serif] text-[clamp(4.3rem,9vw,8rem)] leading-[.88] m-0 uppercase tracking-[-.03em]">Suas histórias.<br><span class="text-[var(--purple)]">Seu jeito.</span></h1>
    <span class="title-brush" aria-hidden="true"></span>
    <p class="text-[#d8d4df] text-xl leading-[1.5] max-w-[470px]">O lugar onde animes, séries, filmes, livros e jogos se encontram. Organize, acompanhe e aproveite cada momento.</p>
    <%= link_to "Começar agora", (user_signed_in? ? dashboard_path : new_user_registration_path), class: "brush-button alt mt-4 min-w-0 uppercase inline-flex items-center justify-center w-fit min-h-[54px] border-0 px-7 text-white font-extrabold cursor-pointer whitespace-nowrap transition-opacity duration-200 hover:opacity-90" %>
  </div>
</section>

<section class="category-strip py-13 px-[6vw] text-center bg-[var(--bg)]">
  <p class="text-[var(--purple-2)] font-['Bebas_Neue',Inter,sans-serif] text-[1.6rem] italic m-0">Tudo que você assiste, lê ou joga.</p>
  <h2 class="font-['Bebas_Neue',Inter,sans-serif] text-[clamp(3rem,6vw,5rem)]">Em um só lugar.</h2>
  <div class="landing-categories grid grid-cols-5 gap-5 mx-auto my-10 max-w-[1080px]">
    <span class="text-[var(--purple)] flex flex-col items-center gap-3"><%= lucide_icon "sparkles", size: 40 %><small class="text-white font-['Bebas_Neue',Inter,sans-serif] text-[1.9rem] italic">Animes</small></span>
    <span class="text-[var(--purple)] flex flex-col items-center gap-3"><%= lucide_icon "tv", size: 40 %><small class="text-white font-['Bebas_Neue',Inter,sans-serif] text-[1.9rem] italic">Séries</small></span>
    <span class="text-[var(--purple)] flex flex-col items-center gap-3"><%= lucide_icon "film", size: 40 %><small class="text-white font-['Bebas_Neue',Inter,sans-serif] text-[1.9rem] italic">Filmes</small></span>
    <span class="text-[var(--purple)] flex flex-col items-center gap-3"><%= lucide_icon "book-open", size: 40 %><small class="text-white font-['Bebas_Neue',Inter,sans-serif] text-[1.9rem] italic">Livros</small></span>
    <span class="text-[var(--purple)] flex flex-col items-center gap-3"><%= lucide_icon "gamepad-2", size: 40 %><small class="text-white font-['Bebas_Neue',Inter,sans-serif] text-[1.9rem] italic">Jogos</small></span>
  </div>
</section>

<section class="pace-section relative isolation-isolate flex items-center min-h-[320px] px-[min(6vw,84px)] py-[clamp(36px,5vw,72px)] overflow-hidden shadow-[inset_0_-1px_0_rgba(255,255,255,.08),0_30px_90px_rgba(0,0,0,.35)]">
  <div class="pace-copy max-w-[530px]">
    <h2 class="font-['Bebas_Neue',Inter,sans-serif] text-[clamp(2.8rem,5vw,4.5rem)] italic leading-[.88] m-0 uppercase tracking-[-.03em] text-shadow-[0_4px_20px_rgba(0,0,0,.72)]">Do seu jeito.<br>No <span class="text-[var(--purple)]">seu ritmo.</span></h2>
    <span class="title-brush" aria-hidden="true"></span>
    <p class="text-[rgba(232,228,238,.78)] mt-0 leading-[1.5] max-w-[470px] text-shadow-[0_2px_16px_rgba(0,0,0,.8)] text-[clamp(0.9rem,1.2vw,1.1rem)]">Acompanhe seu progresso, defina prioridades e nunca perca o que importa.</p>
  </div>
</section>
