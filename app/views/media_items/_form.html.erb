<%= form_with model: media_item, id: "media_item_form", class: "grid", data: (local_assigns[:modal] ? { controller: "tmdb-search steam-search anidb-search form-category", turbo_stream: true, modal_target: "form", action: "input->modal#markDirty change->modal#markDirty turbo:submit-end->modal#onSubmitEnd click@window->tmdb-search#clickOutside click@window->steam-search#clickOutside click@window->anidb-search#clickOutside" } : { controller: "tmdb-search steam-search anidb-search form-category", action: "click@window->tmdb-search#clickOutside click@window->steam-search#clickOutside click@window->anidb-search#clickOutside" }) do |form| %>
  <% if media_item.errors.any? %>
    <div class="px-4 md:px-10 py-4 border-b border-[var(--line)] text-[var(--text)] text-[13px] bg-[var(--panel-muted)]">
      <strong class="block mb-1 text-[11px] tracking-[.12em] uppercase text-[var(--text)]">Revise os campos:</strong>
      <%= media_item.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <section class="px-4 md:px-10 py-4 md:py-10 border-b border-[var(--line)]">
    <h2 class="text-[11px] font-medium tracking-[.12em] uppercase text-[var(--muted)] mb-6">Informações gerais</h2>
    <div class="grid bg-transparent grid-cols-1 md:grid-cols-2 gap-y-6 md:gap-x-6 md:gap-y-8">
      <div class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0">
        <label class="grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">
          Título
          <div class="relative">
            <%= form.text_field :title, required: true, placeholder: "One Piece", autocomplete: "off", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full", data: { tmdb_search_target: "input", steam_search_target: "input", anidb_search_target: "input", action: "input->tmdb-search#search input->steam-search#search input->anidb-search#search keydown->tmdb-search#keydown keydown->steam-search#keydown keydown->anidb-search#keydown" } %>
            <div data-tmdb-search-target="results" data-steam-search-target="results" data-anidb-search-target="results" hidden class="absolute left-0 right-0 top-full z-50 bg-[var(--surface)] border border-[var(--line)] border-t-0 rounded-b-lg shadow-lg max-h-[360px] overflow-y-auto"></div>
          </div>
        </label>
      </div>
      <label class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Categoria<%= form.select :category, MediaItem.categories.keys.map { |key| [category_label(key), key] }, { include_blank: "Selecione uma categoria" }, { data: (local_assigns[:modal] ? { form_category_target: "select", modal_target: "category", action: "change->form-category#change change->modal#onCategoryChange" } : { form_category_target: "select", action: "change->form-category#change" }), class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] appearance-none w-full" } %></label>
      <label class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Status<%= form.select :status, MediaItem.statuses.keys.map { |key| [status_label(key), key] }, { include_blank: "Selecione um status" }, { data: (local_assigns[:modal] ? { modal_target: "status" } : {}), class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] appearance-none w-full" } %></label>
      <label class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Plataforma<%= form.text_field :platform, placeholder: "Crunchyroll, Kindle, Steam...", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full", data: { tmdb_search_target: "platform", steam_search_target: "platform", anidb_search_target: "platform" } %></label>
      <label class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Ano de lançamento<%= form.number_field :release_year, min: 1800, max: 2200, placeholder: "ex: 2024", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full", data: { tmdb_search_target: "releaseYear", steam_search_target: "releaseYear", anidb_search_target: "releaseYear" } %></label>
      <label class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Avaliação (0-10)<%= form.number_field :rating, min: 0, max: 10, placeholder: "0-10", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full" %></label>
      <label class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 col-span-1 md:col-span-2 grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">URL da capa<%= form.url_field :cover_url, placeholder: "https://...", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full", data: { tmdb_search_target: "coverUrl", steam_search_target: "coverUrl", anidb_search_target: "coverUrl" } %></label>
      <label class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 col-span-1 md:col-span-2 grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Descrição<%= form.text_area :description, rows: 4, placeholder: "Sinopse, resumo ou observações sobre esta mídia...", class: "mt-1.5 border border-[var(--line)] px-3 py-2.5 text-[13px] min-h-20 bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full resize-vertical", data: { tmdb_search_target: "description", steam_search_target: "description", anidb_search_target: "description" } %></label>
    </div>
  </section>
  <section class="px-4 md:px-10 py-4 md:py-10 border-b border-[var(--line)]">
    <h2 class="text-[11px] font-medium tracking-[.12em] uppercase text-[var(--muted)] mb-6">Progresso</h2>
    <div class="grid bg-transparent grid-cols-1 md:grid-cols-3 gap-y-6 md:gap-x-6 md:gap-y-8">
      <label class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Data de início<%= form.date_field :started_at, placeholder: "dd/mm/aaaa", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full" %></label>
      <label class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Data de conclusão<%= form.date_field :finished_at, placeholder: "dd/mm/aaaa", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full" %></label>
      <div class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0" data-form-category-target="group" data-category="anime series">
        <label class="grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Temporada atual<%= form.number_field :current_season, min: 0, placeholder: "ex: 1", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full" %></label>
      </div>
      <div class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0" data-form-category-target="group" data-category="anime series">
        <label class="grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Episódio atual<%= form.number_field :current_episode, min: 0, placeholder: "ex: 12", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full" %></label>
      </div>
      <div class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0" data-form-category-target="group" data-category="anime series">
        <label class="grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Total de episódios<%= form.number_field :total_episodes, min: 0, placeholder: "ex: 24", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full", data: { tmdb_search_target: "totalEpisodes", anidb_search_target: "totalEpisodes" } %></label>
      </div>
      <div class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0" data-form-category-target="group" data-category="book">
        <label class="grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Autor<%= form.text_field :author, placeholder: "Nome do autor", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full" %></label>
      </div>
      <div class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0" data-form-category-target="group" data-category="book">
        <label class="grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Página atual<%= form.number_field :current_page, min: 0, placeholder: "ex: 150", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full" %></label>
      </div>
      <div class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0" data-form-category-target="group" data-category="book">
        <label class="grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Total de páginas<%= form.number_field :total_pages, min: 0, placeholder: "ex: 350", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full" %></label>
      </div>
      <div class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0" data-form-category-target="group" data-category="movie anime_movie">
        <label class="grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Duração (min)<%= form.number_field :duration_minutes, min: 0, placeholder: "ex: 120", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full", data: { tmdb_search_target: "duration" } %></label>
      </div>
      <div class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0" data-form-category-target="group" data-category="game">
        <label class="grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Horas jogadas<%= form.number_field :hours_played, min: 0, placeholder: "ex: 40", class: "mt-1.5 border border-[var(--line)] min-h-[40px] px-3 text-[13px] bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full" %></label>
      </div>
      <div class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 col-span-1 md:col-span-2" data-form-category-target="group" data-category="game">
        <div class="flex gap-6 items-end px-2 md:px-[18px] py-[18px] bg-[var(--bg)]">
          <label class="inline-flex items-center gap-2 cursor-pointer normal-case tracking-normal text-sm text-[var(--text)]"><%= form.check_box :wants_platinum, class: "mt-0 w-[18px] h-[18px] min-h-[18px]" %> Deseja platinar</label>
          <label class="inline-flex items-center gap-2 cursor-pointer normal-case tracking-normal text-sm text-[var(--text)]"><%= form.check_box :platinum_completed, class: "mt-0 w-[18px] h-[18px] min-h-[18px]" %> Platinado</label>
        </div>
      </div>
      <label class="px-2 md:px-5 py-[18px] md:border-b border-[var(--line)] [&:last-child]:border-b-0 col-span-1 md:col-span-3 grid gap-1.5 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--muted)]">Notas pessoais<%= form.text_area :notes, rows: 5, placeholder: "Suas impressões, anotações, spoilers...", class: "mt-1.5 border border-[var(--line)] px-3 py-2.5 text-[13px] min-h-20 bg-transparent text-[var(--text)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--tertiary)] placeholder:text-[13px] w-full resize-vertical" %></label>
    </div>
  </section>
  <div class="flex justify-end gap-3 px-4 md:px-10 py-6 border-b border-[var(--line)]">
    <% if local_assigns[:modal] %>
      <button type="button" class="inline-flex items-center justify-center w-fit min-h-[48px] px-5 bg-[var(--panel-muted)] text-[var(--muted)] text-[11px] font-semibold tracking-[.1em] uppercase whitespace-nowrap cursor-pointer font-inherit transition-[background,color,border-color] duration-150 hover:bg-[var(--hover-bg)] hover:text-[var(--text)]" data-action="modal#requestClose">Cancelar</button>
    <% else %>
      <%= link_to "Cancelar", media_item.persisted? ? media_item_path(media_item) : library_path, class: "inline-flex items-center justify-center w-fit min-h-[48px] px-5 bg-[var(--panel-muted)] text-[var(--muted)] text-[11px] font-semibold tracking-[.1em] uppercase whitespace-nowrap cursor-pointer font-inherit transition-[background,color,border-color] duration-150 hover:bg-[var(--hover-bg)] hover:text-[var(--text)]" %>
    <% end %>
    <%= form.submit media_item.persisted? ? "Salvar alterações" : "Criar mídia", class: "inline-flex items-center justify-center w-fit min-h-[48px] px-5 bg-[var(--accent)] text-white text-[11px] font-semibold tracking-[.1em] uppercase whitespace-nowrap cursor-pointer font-inherit border-none transition-[background,color,border-color] duration-150 hover:brightness-110" %>
  </div>
<% end %>
