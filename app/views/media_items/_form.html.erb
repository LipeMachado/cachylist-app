<%= form_with model: media_item, class: "media-form", data: (local_assigns[:modal] ? { modal_target: "form", action: "input->modal#markDirty change->modal#markDirty" } : {}) do |form| %>
  <% if media_item.errors.any? %>
    <div class="form-errors">
      <strong>Revise os campos:</strong>
      <%= media_item.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <section class="form-section">
    <h2>Informações gerais</h2>
    <div class="form-grid two">
      <label>Título<%= form.text_field :title, required: true, placeholder: "One Piece" %></label>
      <label>Categoria<%= form.select :category, MediaItem.categories.keys.map { |key| [category_label(key), key] }, { include_blank: "Selecione uma categoria" }, data: (local_assigns[:modal] ? { modal_target: "category" } : {}) %></label>
      <label>Status<%= form.select :status, MediaItem.statuses.keys.map { |key| [status_label(key), key] }, { include_blank: "Selecione um status" }, data: (local_assigns[:modal] ? { modal_target: "status" } : {}) %></label>
      <label>Plataforma<%= form.text_field :platform, placeholder: "Crunchyroll, Kindle, Steam..." %></label>
      <label>Ano de lançamento<%= form.number_field :release_year, min: 1800, max: 2200, placeholder: "ex: 2024" %></label>
      <label>Avaliação (0-10)<%= form.number_field :rating, min: 0, max: 10, placeholder: "0-10" %></label>
      <label class="span-two">URL da capa<%= form.url_field :cover_url, placeholder: "https://..." %></label>
      <label class="span-two">Descrição<%= form.text_area :description, rows: 4, placeholder: "Sinopse, resumo ou observações sobre esta mídia..." %></label>
    </div>
  </section>

  <section class="form-section">
    <h2>Progresso</h2>
    <div class="form-grid three">
      <label>Data de início<%= form.date_field :started_at, placeholder: "dd/mm/aaaa" %></label>
      <label>Data de conclusão<%= form.date_field :finished_at, placeholder: "dd/mm/aaaa" %></label>
      <label>Temporada atual<%= form.number_field :current_season, min: 0, placeholder: "ex: 1" %></label>
      <label>Episódio atual<%= form.number_field :current_episode, min: 0, placeholder: "ex: 12" %></label>
      <label>Total de episódios<%= form.number_field :total_episodes, min: 0, placeholder: "ex: 24" %></label>
      <label>Autor<%= form.text_field :author, placeholder: "Nome do autor" %></label>
      <label>Página atual<%= form.number_field :current_page, min: 0, placeholder: "ex: 150" %></label>
      <label>Total de páginas<%= form.number_field :total_pages, min: 0, placeholder: "ex: 350" %></label>
      <label>Diretor<%= form.text_field :director, placeholder: "Nome do diretor" %></label>
      <label>Duração (min)<%= form.number_field :duration_minutes, min: 0, placeholder: "ex: 120" %></label>
      <label>Horas jogadas<%= form.number_field :hours_played, min: 0, placeholder: "ex: 40" %></label>
      <div class="check-row">
        <label><%= form.check_box :wants_platinum %> Deseja platinar</label>
        <label><%= form.check_box :platinum_completed %> Platinado</label>
      </div>
      <label class="span-three">Notas pessoais<%= form.text_area :notes, rows: 5, placeholder: "Suas impressões, anotações, spoilers..." %></label>
    </div>
  </section>

  <div class="form-actions">
    <% if local_assigns[:modal] %>
      <button type="button" class="secondary-button" data-action="modal#requestClose">Cancelar</button>
    <% else %>
      <%= link_to "Cancelar", media_item.persisted? ? media_item_path(media_item) : library_path, class: "secondary-button" %>
    <% end %>
    <%= form.submit media_item.persisted? ? "Salvar alterações" : "Criar mídia", class: "primary-button" %>
  </div>
<% end %>
