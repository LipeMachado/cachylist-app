<article class="media-card">
  <%= link_to media_item_path(item), class: "media-card-link" do %>
    <img src="<%= cover_for(item) %>" alt="Capa de <%= item.title %>" class="media-cover">
    <div class="media-card-body">
      <div class="media-card-title-row">
        <strong><%= item.title %></strong>
        <span class="status-dot <%= status_class(item.status) %>"></span>
      </div>
      <p><%= category_label(item.category) %><%= " • #{item.release_year}" if item.release_year.present? %></p>
      <span><%= item.progress_label.presence || item.platform.presence || "-" %></span>
      <% if item.progress_percentage.positive? && !item.completed? %>
        <div class="progress"><span style="width: <%= item.progress_percentage %>%"></span></div>
      <% end %>
    </div>
  <% end %>
</article>
