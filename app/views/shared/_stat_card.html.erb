<article class="grid gap-4 px-6 py-6 border-r border-[var(--line)] bg-[var(--panel-bg)] <%= local_assigns[:accent] %>">
  <div class="flex items-center justify-between gap-3">
    <p class="text-[10px] font-bold tracking-[.16em] uppercase leading-[1.5] text-[var(--muted)] m-0"><%= label %></p>
    <span class="flex items-center justify-center w-[28px] h-[28px] border border-[var(--line)] flex-[0_0_28px] text-[var(--accent)]"><%= icon %></span>
  </div>
  <div>
    <strong class="block text-[clamp(28px,3vw,42px)] leading-none font-black m-0"><%= value %></strong>
    <% if local_assigns[:meta].present? %>
      <small class="block mt-2 text-[10px] font-semibold tracking-[.12em] uppercase text-[var(--tertiary)]"><%= meta %></small>
    <% end %>
  </div>
</article>
