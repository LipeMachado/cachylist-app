<%= render layout: "shared/app_shell" do %>
  <div class="profile-card">
    <span class="avatar big"><%= current_user.display_name.first %></span>
    <h1><%= current_user.display_name %></h1>
    <p><%= current_user.email %></p>
    <div class="profile-actions">
      <%= link_to "Editar perfil", edit_user_registration_path, class: "primary-button" %>
      <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "secondary-button" %>
    </div>
  </div>

  <section class="stats-grid">
    <%= render "shared/stat_card", icon: "◇", label: "Total de Mídias", value: @stats.total, accent: "purple" %>
    <%= render "shared/stat_card", icon: "✓", label: "Concluídas", value: @stats.count(:completed), meta: "#{@stats.percentage(:completed)}%", accent: "green" %>
    <%= render "shared/stat_card", icon: "▷", label: "Em Andamento", value: @stats.count(:in_progress), meta: "#{@stats.percentage(:in_progress)}%", accent: "blue" %>
  </section>
<% end %>
